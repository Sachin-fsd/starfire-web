# Auth.js / NextAuth
# Generate securely: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=
